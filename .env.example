# NARA Swarm Monitor Environment Variables

# The Base Mainnet or local fork Chain ID.
CHAIN_ID=8453

# RPC configuration
BASE_RPC_URL=https://mainnet.base.org
BASE_BACKUP_RPC_URL_1=https://base.publicnode.com
BASE_BACKUP_RPC_URL_2=https://base.drpc.org

# Fresh v4 redeploy values only. No v3 or retired incident-stack addresses.
V4_START_BLOCK=
V4_NARA_TOKEN=
V4_ENGINE=
V4_POSITION_NFT=
V4_BOND_DEPOSITORY_NFT=
V4_BOND_VAULT=
V4_OPS_VAULT=
V4_ENGINE_OPS_ROUTER=
V4_BREAK_GLASS_SAFE=

# Optional fresh v4 addresses.
V4_TREASURY_ADDRESS=
V4_FINAL_ADMIN=
DEPLOYER_ADDRESS=

# Optional fresh v4 liquidity values.
V4_DEX_TYPE=uniswap_v4
V4_UNISWAP_V4_POOL_ID=
V4_LIQUIDITY_HOOK=
V4_LIQUIDITY_VAULT=
V4_LIQUIDITY_COMPOUNDER=

# SQLite / Postgres database URL (Ponder database target)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/nara_monitor

# Read-only Commander v1 SQL endpoint. Defaults to local Ponder API `/sql`.
COMMANDER_SQL_URL=http://localhost:42069/sql

# AI Summarizer v1. Defaults to local_stub and only reads commander_reports.
AI_SUMMARY_PROVIDER=local_stub

# AI Swarm keys (Ollama local endpoint or Gemini API)
GEMINI_API_KEY=

# (Optional) OpenZeppelin Monitor webhook
OZ_MONITOR_WEBHOOK_URL=
